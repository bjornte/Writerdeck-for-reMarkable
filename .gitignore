# ──────────────────────────────────────────────────────────────
# Secrets — NEVER commit real credentials.
# The real file lives on disk only; the *.example template is committed.
# ──────────────────────────────────────────────────────────────
secrets/*
!secrets/README.md
!secrets/*.example

# Belt-and-suspenders: ignore these patterns anywhere in the tree
*.local.env
*.local
.env
.env.*
!.env.example

# SSH keys must never be committed
id_rsa*
id_ed25519*
*.pem
*.key

# ──────────────────────────────────────────────────────────────
# Build artifacts (the Go daemon and friends)
# ──────────────────────────────────────────────────────────────
/Writerdeck-server
/Writerdeck-server.exe
*.o
*.exe
dist/

# Exception: third_party/keywriter/dist/ holds CI-built artifacts
# (Writerdeck binary + qt5.tar.gz); Mac deploy uses fetch-keywriter-dist.sh.
!third_party/keywriter/dist/
!third_party/keywriter/dist/**
# Re-ignore the locally-unpacked qt5/ tree -- only the compressed tarball is
# committed.  deploy-keywriter.sh unpacks and removes it transiently.
third_party/keywriter/dist/qt5/

# ──────────────────────────────────────────────────────────────
# OS / editor cruft
# ──────────────────────────────────────────────────────────────
Thumbs.db
.DS_Store
*.swp

# ──────────────────────────────────────────────────────────────
# Fetched third-party binaries (not committed; see third_party/README.md)
# ──────────────────────────────────────────────────────────────

/third_party/**/*.bin
# Raw qmake TARGET output from build-keywriter.sh (the committed artifact is dist/Writerdeck)
/third_party/keywriter/edit

# ──────────────────────────────────────────────────────────────
# Recon output — local device-test logs (regenerable; not committed).
# ──────────────────────────────────────────────────────────────
/docs/recon/*.txt
/docs/recon/*.tar.gz
keymaps/.tmp/

# Public release: ship source-only. The keywriter binary + qt5.tar.gz are
# CI-built (build-keywriter.yml); they are NOT committed in this public mirror.
third_party/keywriter/dist/Writerdeck
third_party/keywriter/dist/qt5.tar.gz
