# EditorConfig — consistent formatting across Go / PowerShell / web / Markdown.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Go uses tabs by convention (gofmt).
[*.go]
indent_style = tab

# PowerShell: Windows line endings, 4-space indent.
[*.{ps1,psm1,psd1}]
end_of_line = crlf
indent_size = 4

# Markdown: keep trailing whitespace (can be meaningful: hard line breaks).
[*.md]
trim_trailing_whitespace = false
