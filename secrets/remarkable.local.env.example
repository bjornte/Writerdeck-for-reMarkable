# ──────────────────────────────────────────────────────────────
# rM1-Writerdeck — secrets TEMPLATE (committed; safe, contains no secrets).
# Copy this to remarkable.local.env and fill in the real values:
#   Copy-Item secrets\remarkable.local.env.example secrets\remarkable.local.env
# The copy is gitignored and must never be committed.
# ──────────────────────────────────────────────────────────────

# reMarkable 1 root SSH password.
# On device: Settings > Help > Copyrights and licenses > General information
#   (scroll down).  NOTE: changes after every firmware update.
RM_ROOT_PASSWORD=

# Device addresses.
RM_HOST_USB=10.11.99.1
RM_HOST_WIFI=

# iPhone Personal Hotspot (shared Wi-Fi). If home-LAN SSH/deploy times out, check
# whether the Mac and reMarkable are both on the hotspot. Tablet is often
# 172.20.10.5 (DHCP may vary). Override for one session:
#   export RM_HOST=172.20.10.5
# Phone UI: http://172.20.10.5:8000/
RM_HOST_HOTSPOT=172.20.10.5
